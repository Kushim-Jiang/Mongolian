# Generated by: stateless

lookup _.effective {
    sub mvs by mvs.effective;
    sub nnbsp by nnbsp.effective;
    sub fvs1 by fvs1.effective;
    sub fvs2 by fvs2.effective;
    sub fvs3 by fvs3.effective;
    sub fvs4 by fvs4.effective;
} _.effective;

# III.1: Chachlag
# Chachlag - a/e - Chachlag

lookup III.a_e.chachlag {
    lookupflag IgnoreMarks;
    sub mvs' lookup _.effective [@a.isol.for_chachlag @e.isol.for_chachlag]' lookup condition.chachlag;
    lookupflag 0;
} III.a_e.chachlag;

# III.2: Syllabic
# Syllabic - o/u/ö/ü - Marked

lookup III.o_u_oe_ue.marked {
    lookupflag IgnoreMarks;
    sub @consonant.init [@o @u @oe @ue]' lookup condition.marked;
    lookupflag 0;
} III.o_u_oe_ue.marked;

# Syllabic - n/j/y/w - Chachlag_Onset
# Syllabic - h/g - Chachlag_Onset

lookup III.n_j_w_h_g.chachlag_onset {
    lookupflag IgnoreMarks;
    sub [@n.fina.for_chachlag_onset @j.isol.for_chachlag_onset @j.fina.for_chachlag_onset @w.fina.for_chachlag_onset]' lookup condition.chachlag_onset mvs.effective [a.Aa.isol e.Aa.isol];
    sub [@h.fina.for_chachlag_onset @g.fina.for_chachlag_onset]' lookup condition.chachlag_onset mvs.effective a.Aa.isol;
    lookupflag 0;
} III.n_j_w_h_g.chachlag_onset;

# Syllabic - n/d - Onset
# Syllabic - n/d - Devsger

lookup III.n_t_d.onset_and_devsger {
    lookupflag IgnoreMarks;
    sub [@n @d]' lookup condition.onset @vowel;
    sub [@n @t @d]' lookup condition.devsger @consonant;

    lookupflag 0;
} III.n_t_d.onset_and_devsger;

# Syllabic - h/g - Masculine_Onset
# Syllabic - h/g - Feminine
# Syllabic - g - Masculine_Devsger
# Syllabic - g - Feminine

lookup III.h_g.onset_and_devsger_and_gender {
    lookupflag IgnoreMarks;
    sub [@h.init.for_feminine @g.init.for_feminine]' lookup condition.feminine [@consonant @vowel.feminine @vowel.neuter];
    sub @vowel.masculine @g.fina.for_masculine_onset' lookup condition.masculine_onset;

    ignore sub [@h.medi @g.medi]' [@vowel.feminine @vowel.neuter];
    sub @vowel.masculine @g.medi.for_masculine_devsger' lookup condition.masculine_devsger @consonant;

    sub [@h.medi.for_masculine_onset @g.medi.for_masculine_onset]' lookup condition.masculine_onset @vowel.masculine;
    sub @vowel.masculine [@h.medi.for_masculine_onset @g.medi.for_masculine_onset]' lookup condition.masculine_onset;
    lookupflag 0;
} III.h_g.onset_and_devsger_and_gender;

lookup III.sh_g.eac {
    lookupflag IgnoreMarks;
    sub [@t]' lookup condition.onset @eh;

    # MXS21: sh + i -> s + i
    sub [@sh.init.for_devsger @sh.medi.for_devsger]' lookup condition.devsger @i;

    # MGZ12, MGZ62: s/d + g -> s/d + h
    sub [@s @d] @g.medi.for_masculine_devsger' lookup condition.masculine_devsger @vowel.masculine;
    sub [@s @d] @g.fina.for_masculine_devsger' lookup condition.masculine_devsger mvs.effective a.Aa.fina;
} III.sh_g.eac;

# III.3: Particle

lookup III.a_i_u_ue_d.particle.A {
    lookupflag IgnoreMarks;
    sub [mvs nnbsp]' lookup _.effective [@a.init.for_particle @i.isol.for_particle @i.init.for_particle @u.isol.for_particle @u.init.for_particle @u.fina.for_particle @ue.isol.for_particle @ue.init.for_particle @ue.medi.for_particle @ue.fina.for_particle @d.init.for_particle]' lookup condition.particle;
    lookupflag 0;
} III.a_i_u_ue_d.particle.A;

lookup III.a_i_u_ue_d.particle.B {
    lookupflag IgnoreMarks;
    sub [mvs mvs.effective nnbsp nnbsp.effective]' lookup _.effective @consonant.init' [@u.fina.for_particle @ue.medi.for_particle @ue.fina.for_particle]' lookup condition.particle;
    lookupflag 0;
} III.a_i_u_ue_d.particle.B;


lookup III.u_ue_y.dictionary_particle {
    lookupflag IgnoreMarks;
    sub [mvs.effective nnbsp.effective] i.I.init y.Y.medi' lookup condition.dictionary_particle [a.A.medi e.A.medi] [n.A.fina r.R.fina];
    sub [mvs nnbsp]' lookup _.effective y.Y.init' lookup condition.dictionary_particle i.I.fina;
    sub [mvs nnbsp]' lookup _.effective y.Y.init' lookup condition.dictionary_particle i.I.medi n.A.fina;

    # not found in EAC spec
    sub [mvs.effective nnbsp.effective] ue.O.init' lookup condition.dictionary_particle g.G.medi e.A.medi i.I.fina;
    sub [mvs.effective nnbsp.effective] u.O.init' lookup condition.dictionary_particle r.R.medi u.O.medi g.Gh.medi u.U.fina;
    lookupflag 0;
} III.u_ue_y.dictionary_particle;

# III.4: Devsger i

lookup III.i.devsger {
    lookupflag IgnoreMarks;
    @vowel.not_ending_with_I = [a.AA.isol a.Aa.isol @a.init a.A.medi a.A.fina @o.isol @o.init o.O.medi @o.fina u.AO.isol u.U.isol @u.init u.O.medi @u.fina @e.isol e.A.init @e.medi e.A.fina oe.AUe.isol oe.O.medi @oe.fina ue.AUe.isol ue.U.isol ue.O.init ue.O.medi @ue.fina @eh];
    sub @vowel.not_ending_with_I @i' lookup condition.devsger;
    lookupflag 0;
} III.i.devsger;

# III.5: Post-bowed

lookup III.a_e_o_u_oe_ue.post_bowed {
    lookupflag IgnoreMarks;
    @B_P_F_K2_K = [b.B.init b.B.medi b.B.fina p.P.init p.P.medi p.P.fina f.F.init f.F.medi f.F.fina k2.K2.init k2.K2.medi k2.K2.fina k.K.init k.K.medi k.K.fina];
    @G_Gx = [h.G.init h.G.medi g.G.init g.G.medi g.G.fina];
    @o_u_oe_ue.U = [o.U.fina u.U.isol u.U.fina oe.U.fina ue.U.isol ue.U.fina];
    @oe_ue.Ue = [oe.Ue.fina ue.Ue.fina];
    sub @G_Gx e.A.fina' lookup condition.post_bowed;
    sub @B_P_F_K2_K [a.A.fina e.A.fina]' lookup condition.post_bowed;
    sub [@B_P_F_K2_K @G_Gx] [@o_u_oe_ue.U @oe_ue.Ue]' lookup condition.post_bowed;
    lookupflag 0;
} III.a_e_o_u_oe_ue.post_bowed;

lookup III.i.eac {
    # MIZ14: i Onset
    sub [@oe.medi @ue.medi] [fvs1 fvs1.effective fvs2 fvs2.effective] @i' lookup condition.onset;
    sub @ue.init [fvs2.effective] @i' lookup condition.onset;
} III.i.eac;

# III.6: FVS-selected

