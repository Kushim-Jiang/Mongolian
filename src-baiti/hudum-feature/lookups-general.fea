# IIB.2: Cleanup of format controls

lookup IIb.hide_effective_format_controls {
    sub mvs.effective by nil;
    sub nnbsp.effective by nnbsp;
    sub fvs1.effective by nil;
    sub fvs2.effective by nil;
    sub fvs3.effective by nil;
    sub fvs4.effective by nil;
} IIb.hide_effective_format_controls;

lookup IIb.preserve_format_controls.A {
    sub mvs by _mvs _helper;
    sub nnbsp by _nnbsp _helper;
    sub fvs1 by _fvs1 _helper;
    sub fvs2 by _fvs2 _helper;
    sub fvs3 by _fvs3 _helper;
    sub fvs4 by _fvs4 _helper;
    sub nil by _nil _helper;
} IIb.preserve_format_controls.A;

lookup IIb.preserve_format_controls.B {
    sub _mvs _helper by _mvs;
    sub _nnbsp _helper by _nnbsp;
    sub _fvs1 _helper by _fvs1;
    sub _fvs2 _helper by _fvs2;
    sub _fvs3 _helper by _fvs3;
    sub _fvs4 _helper by _fvs4;
    sub _nil _helper by _nil;
} IIb.preserve_format_controls.B;

# IIB.3: Optional treatments
