# III.5: Post-bowed
# IIB.1: Variation involving bowed written units

lookup III.a_e_o_u_oe_ue.post_bowed {
    # TODO
    lookupflag IgnoreMarks;
    @B_P_F_K2_K = [b.B.init b.B.medi b.B.fina p.P.init p.P.medi p.P.fina f.F.init f.F.medi f.F.fina k2.K2.init k2.K2.medi k2.K2.fina k.K.init k.K.medi k.K.fina];
    @G_Gx = [h.G.init h.G.medi g.G.init g.G.medi g.G.fina];
    @o_u_oe_ue.U = [o.U.fina u.U.isol u.U.fina oe.U.fina ue.U.isol ue.U.fina];
    @oe_ue.Ue = [oe.Ue.fina ue.Ue.fina];
    sub @G_Gx e.A.fina' lookup condition.post_bowed;
    sub @B_P_F_K2_K [a.A.fina e.A.fina]' lookup condition.post_bowed;
    sub [@B_P_F_K2_K @G_Gx] [@o_u_oe_ue.U @oe_ue.Ue]' lookup condition.post_bowed;
    lookupflag 0;
} III.a_e_o_u_oe_ue.post_bowed;

# IIB.3: Optional treatments
