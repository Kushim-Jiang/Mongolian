# Generated by: stateless

@consonant.init = [@n.init @ng.init @b.init @p.init @h.init @g.init @m.init @l.init @s.init @sh.init @t.init @d.init @ch.init @j.init @y.init @r.init @w.init @f.init @k2.init @k.init @c.init @z.init @hh.init @rh.init @lh.init @zr.init @cr.init];
@mcs = [mvs nnbsp];
@mcs.effe = [mvs.effe nnbsp.effe];
@fvs = [fvs1 fvs2 fvs3 fvs4];
@fvs.effe = [fvs1.effe fvs2.effe fvs3.effe fvs4.effe];

# IIB.2: Cleanup of format controls

lookup _.effe {
    sub @mcs by @mcs.effe;
    sub @fvs by @fvs.effe;
} _.effe;

lookup _.nomi {
    sub @fvs.effe by @fvs;
} _.nomi;

# III.1: Chachlag
# Chachlag - a/e - Chachlag

lookup III.a_e.chachlag {
    lookupflag IgnoreMarks;
    sub @mcs.effe [@a.isol.for_chachlag @e.isol.for_chachlag]' lookup condition.chachlag;
    lookupflag 0;
} III.a_e.chachlag;

# III.2: Syllabic
# Syllabic - o/u/ö/ü - Marked

lookup III.o_u_oe_ue.marked {
    lookupflag IgnoreMarks;
    sub @consonant.init [@o @u @oe @ue]' lookup condition.marked;
    lookupflag 0;
} III.o_u_oe_ue.marked;

# Syllabic - n/j/y/w - Chachlag_Onset
# Syllabic - h/g - Chachlag_Onset

lookup III.n_j_w_h_g.chachlag_onset {
    lookupflag IgnoreMarks;
    sub [@n.fina.for_chachlag_onset @j.isol.for_chachlag_onset @j.fina.for_chachlag_onset @w.fina.for_chachlag_onset]' lookup condition.chachlag_onset mvs.effe [a.Aa.isol e.Aa.isol];
    sub [@h.fina.for_chachlag_onset @g.fina.for_chachlag_onset]' lookup condition.chachlag_onset mvs.effe a.Aa.isol;
    lookupflag 0;
} III.n_j_w_h_g.chachlag_onset;

# Syllabic - n/d - Onset
# Syllabic - n/d - Devsger

lookup III.n_t_d.onset_and_devsger {
    lookupflag IgnoreMarks;
    sub [@t]' lookup condition.onset @eh;
    sub [@n @t @d]' lookup condition.devsger @consonant;
    # MXS21 (Controversial): sh + i -> s + i
    # sub [@sh.init.for_devsger @sh.medi.for_devsger]' lookup condition.devsger @i;
    lookupflag 0;
} III.n_t_d.onset_and_devsger;

# Syllabic - h/g - Masculine_Onset
# Syllabic - h/g - Feminine
# Syllabic - g - Masculine_Devsger
# Syllabic - g - Feminine

lookup III.h_g.onset_and_devsger_and_gender {
    lookupflag IgnoreMarks;
    sub [@h.init.for_feminine @g.init.for_feminine]' lookup condition.feminine [@consonant @vowel.feminine @vowel.neuter];
    sub @vowel.masculine @g.fina.for_masculine_onset' lookup condition.masculine_onset;

    ignore sub [@h.medi @g.medi]' [@vowel.feminine @vowel.neuter];
    sub @vowel.masculine @g.medi.for_masculine_devsger' lookup condition.masculine_devsger @consonant;
    # MGZ12, MGZ62 (Controversial): s/t + g -> s/t + h
    # sub [@s @t] @g.medi.for_masculine_devsger' lookup condition.masculine_devsger @vowel.masculine;
    # sub [@s @t] @g.fina.for_masculine_devsger' lookup condition.masculine_devsger mvs.effe a.Aa.fina;
    sub [@h.medi.for_masculine_onset @g.medi.for_masculine_onset]' lookup condition.masculine_onset @vowel.masculine;
    sub @vowel.masculine [@h.medi.for_masculine_onset @g.medi.for_masculine_onset]' lookup condition.masculine_onset;
    lookupflag 0;
} III.h_g.onset_and_devsger_and_gender;

# III.3: Particle

lookup III.a_i_u_ue_d.particle.A {
    lookupflag IgnoreMarks;
    sub [mvs.effe nnbsp.effe] [@a.init.for_particle @i.isol.for_particle @i.init.for_particle @u.isol.for_particle @u.init.for_particle @u.fina.for_particle @ue.isol.for_particle @ue.init.for_particle @ue.medi.for_particle @ue.fina.for_particle @d.init.for_particle]' lookup condition.particle;
    lookupflag 0;
} III.a_i_u_ue_d.particle.A;

lookup III.a_i_u_ue_d.particle.B {
    lookupflag IgnoreMarks;
    sub [mvs.effe nnbsp.effe] @consonant.init' [@u.fina.for_particle @ue.medi.for_particle @ue.fina.for_particle]' lookup condition.particle;
    lookupflag 0;
} III.a_i_u_ue_d.particle.B;

lookup III.ue_y.dictionary_particle {
    lookupflag IgnoreMarks;
    sub [mvs.effe nnbsp.effe] i.I.init y.Y.medi' lookup condition.dictionary_particle [a.A.medi e.A.medi] [n.A.fina r.R.fina];
    sub [mvs.effe nnbsp.effe] y.Y.init' lookup condition.dictionary_particle i.I.fina;
    sub [mvs.effe nnbsp.effe] y.Y.init' lookup condition.dictionary_particle i.I.medi n.A.fina;
    # not found in EAC spec
    sub [mvs.effe nnbsp.effe] ue.O.init' lookup condition.dictionary_particle g.G.medi e.A.medi i.I.fina;
    sub [mvs.effe nnbsp.effe] u.O.init' lookup condition.dictionary_particle r.R.medi u.O.medi g.Gh.medi u.U.fina;
    lookupflag 0;
} III.ue_y.dictionary_particle;

# III.4: Devsger i

lookup III.i.devsger {
    lookupflag IgnoreMarks;
    @vowel.not_ending_with_I = [a.AA.isol a.Aa.isol @a.init a.A.medi a.A.fina @o.isol @o.init o.O.medi @o.fina u.AO.isol u.U.isol @u.init u.O.medi @u.fina @e.isol e.A.init @e.medi e.A.fina oe.AUe.isol oe.O.medi @oe.fina ue.AUe.isol ue.U.isol ue.O.init ue.O.medi @ue.fina @eh];
    sub @vowel.not_ending_with_I @i' lookup condition.devsger;
    lookupflag 0;
} III.i.devsger;

# MIZ14: i Onset

lookup III.i.onset {
    sub [@oe.medi @ue.medi] [fvs1 fvs1.effe fvs2 fvs2.effe] @i' lookup condition.onset;
    sub @ue.init [fvs2 fvs2.effe] @i' lookup condition.onset;
} III.i.onset;

# III.6: FVS-selected

