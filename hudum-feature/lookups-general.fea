    sub @u.init fvs1 by u.O.init;
    sub @u.medi fvs1 by u.AO.medi;
    sub @u.fina fvs2 by u.U.fina;
    sub @u.fina fvs1 by u.O.fina;
    sub @oe.isol fvs1 by oe.AU.isol;
    sub @oe.medi fvs3 by oe.O.medi;
    sub @oe.medi fvs1 by oe.OI.medi;
