# III.1: Chachlag
# Chachlag - a/e - Chachlag

@a.isol.for_chachlag = [a.AA.isol];
@e.isol.for_chachlag = [e.A.isol];
lookup condition.chachlag {
    sub @a.isol.for_chachlag by a.Aa.isol;
    sub @e.isol.for_chachlag by e.Aa.isol;
} condition.chachlag;

