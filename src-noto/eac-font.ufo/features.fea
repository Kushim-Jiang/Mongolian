    sub @t.medi fvs1 by t.T.medi;
    sub @d.isol fvs1 by d.T.isol;
    sub @d.init fvs2 by d.T.init;
    sub @d.init fvs1 by d.D.init;
    sub @d.medi fvs2 by d.Dd.medi;
    sub @d.medi fvs1 by d.D.medi;
