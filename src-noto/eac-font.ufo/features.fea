    sub @g.fina fvs1 by g.H.fina;
    sub @g.fina fvs2 by g.G.fina;
    sub @g.fina fvs3 by g.Gh.fina;
    sub @s.fina fvs1 by s.S2.fina;
    sub @sh.isol fvs1 by sh.S.isol;
    sub @sh.init fvs2 by sh.Sh.init;
    sub @sh.init fvs1 by sh.S.init;
    sub @sh.medi fvs2 by sh.Sh.medi;
    sub @sh.medi fvs1 by sh.S.medi;
