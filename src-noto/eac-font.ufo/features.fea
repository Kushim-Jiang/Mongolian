    sub @u.fina fvs2 by u.U.fina;
    sub @u.fina fvs1 by u.O.fina;
    sub @oe.isol fvs1 by oe.AU.isol;
    sub @oe.medi fvs3 by oe.O.medi;
    sub @oe.medi fvs1 by oe.OI.medi;
    sub @oe.medi fvs2 by oe.AOI.medi;
    sub @oe.fina fvs3 by oe.U.fina;
    sub @oe.fina fvs1 by oe.Ue.fina;
    sub @oe.fina fvs2 by oe.O.fina;
    sub @ue.isol fvs1 by ue.AU.isol;
    sub @ue.isol fvs2 by ue.U.isol;
    sub @ue.isol fvs3 by ue.Ux.isol;
    sub @ue.init fvs2 by ue.AOI.init;
    sub @ue.init fvs1 by ue.O.init;
    sub @ue.medi fvs3 by ue.O.medi;
    sub @ue.medi fvs1 by ue.OI.medi;
    sub @ue.medi fvs2 by ue.AOI.medi;
    sub @ue.fina fvs3 by ue.U.fina;
    sub @ue.fina fvs1 by ue.Ue.fina;
    sub @ue.fina fvs2 by ue.O.fina;
    sub @n.isol fvs1 by n.A.isol;
    sub @n.init fvs1 by n.A.init;
    sub @n.medi fvs2 by n.A.medi;
    sub @n.medi fvs1 by n.N.medi;
    sub @n.fina fvs2 by n.A.fina;
    sub @n.fina fvs1 by n.N.fina;
    sub @b.fina fvs1 by b.B2.fina;
    sub @h.isol fvs1 by h.Gh.isol;
    sub @h.isol fvs2 by h.G.isol;
    sub @h.isol fvs4 by h.Gx.isol;
    sub @h.init fvs3 by h.H.init;
    sub @h.init fvs1 by h.Gh.init;
